<ui:FluentWindow x:Class="TaskbarLyrics.App.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="TaskbarLyrics - 璁剧疆"
                 Width="1280"
                 Height="860"
                 MinWidth="1080"
                 MinHeight="720"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="None"
                 ResizeMode="CanResize"
                 Background="Transparent"
                 Foreground="#F8FAFC"
                 WindowBackdropType="Acrylic"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True">
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#D9070E1D" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#A8070E1D" />
        <SolidColorBrush x:Key="SurfaceCardBrush" Color="#B80B1528" />
        <SolidColorBrush x:Key="SurfaceItemBrush" Color="#AA0B1528" />
        <SolidColorBrush x:Key="SurfaceInputBrush" Color="#CC0B1528" />
        <SolidColorBrush x:Key="BorderBrush" Color="#1A78A0FF" />
        <SolidColorBrush x:Key="BorderSoftBrush" Color="#1A78A0FF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4D7AFF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#6B91FF" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#315DE6" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CCFFFFFF" />
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="#73FFFFFF" />
        <SolidColorBrush x:Key="SwitchOffBrush" Color="#334155" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Microsoft YaHei UI" />
        </Style>

        <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CardTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ItemTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="Rail"
                                        Width="3"
                                        Height="22"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="-8,0,0,0"
                                        CornerRadius="2"
                                        Background="{StaticResource AccentHoverBrush}"
                                        Opacity="0" />
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0AFFFFFF" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="Chrome" Property="Background" Value="#244D7AFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#334D7AFF" />
                                <Setter TargetName="Rail" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="#EAF2FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Background" Value="{StaticResource SurfaceCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="PlayerItemStyle" TargetType="Border">
            <Setter Property="Height" Value="52" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource SurfaceItemBrush}" />
            <Setter Property="BorderBrush" Value="#26344D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="RecognitionOrderListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#104D7AFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="60" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="{StaticResource SurfaceItemBrush}" />
            <Setter Property="BorderBrush" Value="#26344D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid Width="44" Height="24">
                            <Border x:Name="Track"
                                    Background="{StaticResource SwitchOffBrush}"
                                    BorderBrush="#475569"
                                    BorderThickness="1"
                                    CornerRadius="12" />
                            <Ellipse x:Name="Thumb"
                                     Width="20"
                                     Height="20"
                                     Margin="2,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="White" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Thumb" Property="Margin" Value="22,0,0,0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ui:TextBox">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Width" Value="280" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceInputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="ClearButtonEnabled" Value="False" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Width" Value="260" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceInputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#144D7AFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#244D7AFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFF7ED" />
            <Setter Property="Background" Value="#7C2D12" />
            <Setter Property="BorderBrush" Value="#C2410C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Close" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="Background" Value="#E81123" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Close" />
                                    <Condition Property="IsPressed" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="Background" Value="#C50F1F" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Border Height="40"
                VerticalAlignment="Top"
                Panel.ZIndex="10"
                Background="#01000000"
                MouseLeftButtonDown="CaptionDragArea_MouseLeftButtonDown" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="20">
            <Button Style="{StaticResource CaptionButtonStyle}"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="MinimizeButton_Click">
                <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
            </Button>
            <Button Style="{StaticResource CaptionButtonStyle}"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="MaximizeRestoreButton_Click">
                <TextBlock x:Name="MaximizeRestoreIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
            </Button>
            <Button Style="{StaticResource CaptionButtonStyle}"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Tag="Close"
                    Click="CloseButton_Click">
                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
            </Button>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="#25334D"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="72" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="24,40,24,0"
                                VerticalAlignment="Top">
                        <TextBlock Text="&#xE93C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="28"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,12,0" />
                        <TextBlock Text="TaskbarLyrics"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="14,4,14,0">
                        <Button x:Name="RecognitionNavButton" Style="{StaticResource SidebarButtonStyle}" Click="RecognitionNavButton_Click" Tag="Selected">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="28" Margin="0,0,10,0" />
                                <TextBlock Text="播放器" FontSize="15" FontWeight="Medium" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DisplayNavButton" Style="{StaticResource SidebarButtonStyle}" Click="DisplayNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Aa" FontSize="16" Width="28" Margin="0,0,10,0" />
                                <TextBlock Text="歌词" FontSize="15" FontWeight="Medium" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="FontNavButton" Style="{StaticResource SidebarButtonStyle}" Click="FontNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="28" Margin="0,0,10,0" />
                                <TextBlock Text="外观" FontSize="15" FontWeight="Medium" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="LayoutNavButton" Style="{StaticResource SidebarButtonStyle}" Click="LayoutNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xECA5;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="28" Margin="0,0,10,0" />
                                <TextBlock Text="布局" FontSize="15" FontWeight="Medium" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DebugNavButton" Style="{StaticResource SidebarButtonStyle}" Click="DebugNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="28" Margin="0,0,10,0" />
                                <TextBlock Text="调试" FontSize="15" FontWeight="Medium" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="24,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0" />
                        <TextBlock Text="设置" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="SettingsContentScrollViewer"
                          Grid.Column="1"
                          Margin="0,40,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent"
                          ScrollChanged="SettingsContentScrollViewer_ScrollChanged">
                <Grid Margin="40,8,36,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <StackPanel>
                            <TextBlock Text="外观" Style="{StaticResource PageTitleTextStyle}" />
                            <TextBlock Text="调整播放器识别、歌词显示、外观和任务栏布局。"
                                       Style="{StaticResource DescriptionTextStyle}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                        <Border Width="56"
                                Height="56"
                                CornerRadius="14"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                BorderBrush="#553B82F6"
                                BorderThickness="1"
                                Background="#991E293B">
                            <TextBlock Text="&#xE93C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="28"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <Border x:Name="RecognitionSection" Grid.Row="2" Style="{StaticResource SettingCardStyle}">
                        <StackPanel>
                            <TextBlock Text="播放器集成" Style="{StaticResource CardTitleTextStyle}" />
                            <TextBlock Text="选择要监听的音乐播放器，并通过拖拽调整优先识别顺序。"
                                       Style="{StaticResource DescriptionTextStyle}"
                                       Margin="0,4,0,16" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PlayerItemStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" CornerRadius="10" Background="#1AFFFFFF">
                                            <Image Source="/TaskbarLyrics.App;component/Assets/PlayerIcons/QQ音乐.png"
                                                   Width="24"
                                                   Height="24"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="QQ音乐" Style="{StaticResource ItemTitleTextStyle}" Margin="14,0,0,0" />
                                        <CheckBox x:Name="QQMusicCheckBox" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PlayerItemStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" CornerRadius="10" Background="#1AFFFFFF">
                                            <Image Source="/TaskbarLyrics.App;component/Assets/PlayerIcons/网易云音乐.png"
                                                   Width="24"
                                                   Height="24"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="网易云音乐" Style="{StaticResource ItemTitleTextStyle}" Margin="14,0,0,0" />
                                        <CheckBox x:Name="NeteaseCheckBox" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PlayerItemStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" CornerRadius="10" Background="#1AFFFFFF">
                                            <Image Source="/TaskbarLyrics.App;component/Assets/PlayerIcons/酷狗音乐.png"
                                                   Width="24"
                                                   Height="24"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="酷狗音乐" Style="{StaticResource ItemTitleTextStyle}" Margin="14,0,0,0" />
                                        <CheckBox x:Name="KugouCheckBox" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource PlayerItemStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" CornerRadius="10" Background="#1AFFFFFF">
                                            <Image Source="/TaskbarLyrics.App;component/Assets/PlayerIcons/spotify.png"
                                                   Width="24"
                                                   Height="24"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="Spotify" Style="{StaticResource ItemTitleTextStyle}" Margin="14,0,0,0" />
                                        <CheckBox x:Name="SpotifyCheckBox" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Margin="0,18,0,0"
                                    CornerRadius="12"
                                    Background="#88101827"
                                    BorderBrush="#26344D"
                                    BorderThickness="1"
                                    Padding="0"
                                    ClipToBounds="True">
                                <ListBox x:Name="RecognitionOrderListBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         ItemContainerStyle="{StaticResource RecognitionOrderListBoxItemStyle}"
                                         AllowDrop="True"
                                         PreviewMouseLeftButtonDown="RecognitionOrderListBox_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="RecognitionOrderListBox_PreviewMouseMove"
                                         DragOver="RecognitionOrderListBox_DragOver"
                                         Drop="RecognitionOrderListBox_Drop">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="40"
                                                    BorderBrush="#1478A0FF"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="18,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="&#xE8FD;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextTertiaryBrush}"
                                                               Opacity="0.7"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding DisplayName}"
                                                               FontSize="14"
                                                               FontWeight="Medium"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DisplaySection" Grid.Row="4" Style="{StaticResource SettingCardStyle}">
                        <StackPanel>
                            <TextBlock Text="歌词设置" Style="{StaticResource CardTitleTextStyle}" />
                            <TextBlock Text="控制歌词窗口启动行为、翻译与显示辅助项。" Style="{StaticResource DescriptionTextStyle}" Margin="0,4,0,16" />
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="启动时显示歌词" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="应用启动后自动显示歌词悬浮窗口。" Style="{StaticResource DescriptionTextStyle}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="StartupCheckBox" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="显示歌词翻译" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="统一控制各歌词源的翻译显示。" Style="{StaticResource DescriptionTextStyle}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="LyricTranslationCheckBox" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="显示背景" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="为歌词窗口启用半透明背景。" Style="{StaticResource DescriptionTextStyle}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="BackgroundCheckBox" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}" Margin="0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="显示边框" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="为歌词窗口绘制边框，便于深浅背景上分辨。" Style="{StaticResource DescriptionTextStyle}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="BorderCheckBox" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FontSection" Grid.Row="6" Style="{StaticResource SettingCardStyle}">
                        <StackPanel>
                            <TextBlock Text="外观" Style="{StaticResource CardTitleTextStyle}" />
                            <TextBlock Text="调整歌词字体、字号和文字颜色。" Style="{StaticResource DescriptionTextStyle}" Margin="0,4,0,16" />
                            <Border Style="{StaticResource SettingRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="字号" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" /><ui:TextBox x:Name="FontSizeTextBox" Grid.Column="1" /></Grid></Border>
                            <Border Style="{StaticResource SettingRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="字体" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" /><ComboBox x:Name="FontFamilyComboBox" Grid.Column="1" IsEditable="True" IsTextSearchEnabled="True" /></Grid></Border>
                            <Border Style="{StaticResource SettingRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="字重" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" /><ComboBox x:Name="FontWeightComboBox" Grid.Column="1"><ComboBoxItem Content="细体" /><ComboBoxItem Content="常规" /><ComboBoxItem Content="中等" /><ComboBoxItem Content="半粗体" /><ComboBoxItem Content="粗体" /></ComboBox></Grid></Border>
                            <Border Style="{StaticResource SettingRowStyle}" Margin="0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="文字颜色" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" /><ui:TextBox x:Name="ForegroundColorTextBox" Grid.Column="1" /></Grid></Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="LayoutSection" Grid.Row="8" Style="{StaticResource SettingCardStyle}">
                        <StackPanel>
                            <TextBlock Text="窗口设置" Style="{StaticResource CardTitleTextStyle}" />
                            <TextBlock Text="调整任务栏歌词窗口的位置、宽度与透明度。" Style="{StaticResource DescriptionTextStyle}" Margin="0,4,0,16" />
                            <Border Style="{StaticResource SettingRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="背景不透明度" FontSize="14" FontWeight="SemiBold" /><TextBlock Text="范围 0 到 1，数值越大背景越不透明。" Style="{StaticResource DescriptionTextStyle}" /></StackPanel><ui:TextBox x:Name="BackgroundOpacityTextBox" Grid.Column="1" /></Grid></Border>
                            <Border Style="{StaticResource SettingRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="窗口宽度 (px)" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" /><ui:TextBox x:Name="WindowWidthTextBox" Grid.Column="1" /></Grid></Border>
                            <Border Style="{StaticResource SettingRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="水平锚点" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" /><ComboBox x:Name="AnchorComboBox" Grid.Column="1"><ComboBoxItem Content="左侧" /><ComboBoxItem Content="居中" /><ComboBoxItem Content="右侧" /></ComboBox></Grid></Border>
                            <Border Style="{StaticResource SettingRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="X 偏移 (px)" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" /><ui:TextBox x:Name="XOffsetTextBox" Grid.Column="1" /></Grid></Border>
                            <Border Style="{StaticResource SettingRowStyle}" Margin="0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Y 偏移 (px)" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" /><ui:TextBox x:Name="YOffsetTextBox" Grid.Column="1" /></Grid></Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DebugSection" Grid.Row="10" Style="{StaticResource SettingCardStyle}">
                        <StackPanel>
                            <TextBlock Text="数据与调试" Style="{StaticResource CardTitleTextStyle}" />
                            <TextBlock Text="清理缓存或打开辅助调试选项。" Style="{StaticResource DescriptionTextStyle}" Margin="0,4,0,16" />
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="SMTC 时间轴监视器" FontSize="14" FontWeight="SemiBold" /><TextBlock Text="用于观察播放器时间轴数据，排查同步问题。" Style="{StaticResource DescriptionTextStyle}" /></StackPanel>
                                    <CheckBox x:Name="SmtcTimelineMonitorCheckBox" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}" Margin="0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="歌词缓存" FontSize="14" FontWeight="SemiBold" /><TextBlock Text="清除后首次重新匹配会稍慢。" Style="{StaticResource DescriptionTextStyle}" /></StackPanel>
                                    <Button Grid.Column="1" Content="清除缓存" Style="{StaticResource DangerButtonStyle}" Click="ClearLyricCacheButton_Click" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Border Grid.Column="1"
                    Height="40"
                    VerticalAlignment="Top"
                    Panel.ZIndex="5"
                    IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#660B1220" Offset="0" />
                        <GradientStop Color="#220B1220" Offset="0.65" />
                        <GradientStop Color="#000B1220" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>

